{
  "name": "tasty-nextjs-example",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tenphi/tasty.style.git"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "predev": "cp -r ../tasty/assets public/assets 2>/dev/null || true",
    "dev": "next dev",
    "prebuild": "cp -r ../tasty/assets public/assets 2>/dev/null || true",
    "build": "next build",
    "postbuild": "pagefind --site out",
    "start": "npx serve@latest out",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hygiene": "eslint . && prettier --check .",
    "hygiene:fix": "eslint . --fix && prettier --write ."
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.28.6",
    "@tabler/icons-react": "^3.40.0",
    "@tenphi/glaze": "0.7.0",
    "@tenphi/tasty": "0.15.2",
    "babel-loader": "^10.1.1",
    "github-slugger": "^2.0.0",
    "next": "^16.0.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tenphi/eslint-plugin-tasty": "0.4.3",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.39.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "browserslist": [
    "chrome >= 120",
    "edge >= 120",
    "firefox >= 121",
    "safari >= 17.2"
  ]
}
