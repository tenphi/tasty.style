{
  "name": "tasty-nextjs-example",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/tenphi/tasty.style.git"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build:examples": "node scripts/build-examples.mjs",
    "playground:snapshot": "node scripts/build-playground-snapshot.mjs",
    "predev": "pnpm build:examples && cp -r ../tasty/assets public/assets 2>/dev/null || true; cp app/playground/coi-serviceworker-custom.js public/coi-serviceworker.js; pnpm playground:snapshot",
    "dev": "next dev",
    "prebuild": "pnpm build:examples && cp -r ../tasty/assets public/assets 2>/dev/null || true; cp app/playground/coi-serviceworker-custom.js public/coi-serviceworker.js; pnpm playground:snapshot",
    "build": "next build",
    "postbuild": "pagefind --site out",
    "start": "npx serve@latest out",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hygiene": "eslint . && prettier --check .",
    "hygiene:fix": "eslint . --fix && prettier --write ."
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.28.6",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@react-aria/interactions": "^3.27.1",
    "@tabler/icons-react": "^3.40.0",
    "@tenphi/glaze": "0.9.2",
    "@tenphi/tasty": "0.0.0-snapshot.23dbfd6",
    "@webcontainer/api": "^1.6.1",
    "babel-loader": "^10.1.1",
    "codemirror": "^6.0.2",
    "coi-serviceworker": "^0.1.7",
    "fflate": "^0.8.2",
    "github-slugger": "^2.0.0",
    "lz-string": "^1.5.0",
    "next": "^16.0.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tenphi/eslint-plugin-tasty": "0.6.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@webcontainer/snapshot": "^0.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.39.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "browserslist": [
    "chrome >= 120",
    "edge >= 120",
    "firefox >= 121",
    "safari >= 17.2"
  ]
}
